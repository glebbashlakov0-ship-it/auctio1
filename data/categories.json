[
  {
    "id": "7cd68ab6-447d-4f1e-8e5f-e289b5f1db7c",
    "name": "Bags & Fashion",
    "slug": "bags-fashion",
    "description": "Discover your next Hermès bag, including the always coveted Birkin bag or the forever classic Hermès Kelly bag. Shop Chanel bags both modern and vintage, or a Louis Vuitton purse in the classic monogram.",
    "parent_id": null,
    "is_active": true,
    "category_translations": [
      {
        "name": "Sac",
        "language": "fr",
        "description": "Découvrez votre prochaine pochette Hermès, y compris la toujours convoitée pochette Birkin ou la classique éternelle pochette Hermès Kelly. Achetez des sacs Chanel, à la fois modernes et vintage, ou une pochette Louis Vuitton dans le classique monogramme."
      },
      {
        "name": "Bags & Fashion",
        "language": "en",
        "description": "Discover your next Hermès bag, including the always coveted Birkin bag or the forever classic Hermès Kelly bag. Shop Chanel bags both modern and vintage, or a Louis Vuitton purse in the classic monogram."
      },
      {
        "name": "Kabelky",
        "language": "cs",
        "description": "<em>Odhalte své další kabelky od Hermès, včetně vždy vyhledávané kabelky Birkin nebo věčně klasické kabelky Hermès Kelly.</em> \n <br>\n <strong>Nakupujte kabelky Chanel, ať už moderní nebo vintage, nebo kabelku Louis Vuitton v klasickém monogramu.</strong>"
      },
      {
        "name": "Bolsa",
        "language": "es",
        "description": "Descubre tu próxima bolsa de Hermès, incluyendo la siempre codiciada bolsa Birkin o la clásica bolsa Hermès Kelly para siempre. Compra bolsas Chanel, tanto modernas como vintage, o una bolsa Louis Vuitton en el clásico monograma."
      },
      {
        "name": "Taschen",
        "language": "de",
        "description": "Entdecken Sie Ihre nächste Hermès-Tasche, einschließlich der immer begehrten Birkin-Tasche oder der ewigen Klassiker Hermès Kelly-Tasche. Kaufen Sie Chanel-Taschen sowohl modern als auch vintage, oder eine Louis Vuitton-Tasche im klassischen Monogramm."
      },
      {
        "name": "Tasjer",
        "language": "no",
        "description": "Oppdag din neste Hermès-behandling, inkludert den alltid ettertraktede Birkin-behandling eller den evige klassiske Hermès Kelly-behandling.  Kjøp Chanel-behandling både moderne og vintage, eller en Louis Vuitton-håndtaske i klassisk monogram."
      },
      {
        "name": "Tas",
        "language": "sv",
        "description": "Upptäck din nästa Hermès-väska, inklusive den alltid eftertraktade Birkin-väskan eller den eviga klassiska Hermès Kelly-väskan. Handla Chanel-väskor både moderna och vintage, eller en Louis Vuitton-handvärk i det klassiska monogrammet."
      },
      {
        "name": "Kemer",
        "language": "tr",
        "description": "Keşfediniz bir sonraki Hermès çantasını, daima arzu edilen Birkin çantasını veya sonsuz klasik Hermès Kelly çantasını. Chanel çantalarını hem modern hem de vintage olarak satın alın, ya da klasik monogramda Louis Vuitton bir kemer."
      },
      {
        "name": "Torby",
        "language": "pl",
        "description": "Odkryj swoją następną torebkę Hermès, w tym zawsze pożądany Birkin lub klasyka na zawsze Hermès Kelly. Kupuj torebki Chanel zarówno nowoczesne jak i w stylu vintage, lub torebkę Louis Vuitton w klasycznym monogramie."
      },
      {
        "name": "Taske",
        "language": "da",
        "description": "Opdag din næste Hermès taske, herunder den altid eftertragte Birkin taske eller den evigt klassiske Hermès Kelly taske. Køb Chanel-taske både moderne og vintage, eller en Louis Vuitton-håndtaske i det klassiske monogram."
      },
      {
        "name": "Valize",
        "language": "ro",
        "description": "Descoperă următorul său sac Hermès, inclusiv sacul Birkin, mereu dorit, sau sacul Hermès Kelly, clasic pentru totdeauna. Cumpărați saci Chanel, atât moderni, cât și vechi, sau o purică Louis Vuitton în monograma clasică."
      },
      {
        "name": "حقيبة",
        "language": "ar",
        "description": "اكتشف حقيبتك التالية من ماركة هرمس، بما في ذلك الحقيبة المشهورة دائمًا بيركين أو الحقيبة الكلاسيكية دائمًا هرمس كيلي. استمتع بمتجر حقيبات تشاليلي الحديثة والقديمة، أو حقيبة لويس فيتون في الطراز الكلاسيكي للمونوغرام."
      },
      {
        "name": "袋",
        "language": "zh",
        "description": "<p>发现您的下一个赫尔梅斯包，包括永远受人追捧的伯金包或永远经典的赫尔梅斯凯利包。 </p><p>购买香奈儿包，现代和经典的，或者路易威登包，经典的格子图案。</p>"
      },
      {
        "name": "Tassen",
        "language": "nl",
        "description": "Ontdek uw volgende Hermès tas, inclusief de altijd begeerde Birkin tas of de eeuwige klassieke Hermès Kelly tas. Koop Chanel tassen zowel modern als vintage, of een Louis Vuitton tas in het klassieke monogram."
      },
      {
        "name": "Bolsas",
        "language": "pt",
        "description": "Descubra sua próxima bolsa Hermès, incluindo a sempre cobiçada bolsa Birkin ou a clássica e eterna bolsa Hermès Kelly. Compre bolsas Chanel, tanto modernas quanto vintage, ou uma bolsa Louis Vuitton no clássico monograma."
      },
      {
        "name": "Borsa",
        "language": "it",
        "description": "Scopri la tua prossima borsa Hermès, inclusa la sempre ambita borsa Birkin o la classica e sempre attuale borsa Hermès Kelly. Acquista borse Chanel, sia moderne che d'epoca, o una borsa Louis Vuitton con il classico monogramma."
      }
    ]
  },
